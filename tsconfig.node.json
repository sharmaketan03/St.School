{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-node",
    "noEmit": false,                 // JS output sirf optional, important: declaration generate ho
    "emitDeclarationOnly": true,     // ✅ d.ts files generate karega, JS ignore
    "allowImportingTsExtensions": true, // ✅ Node scripts ke liye allowed
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "scripts/**/*.ts"]
}